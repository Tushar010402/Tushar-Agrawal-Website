import serial import numpy as np import matplotlib.pyplot as plt

62
00:05:27,800 --> 00:05:30,877
Now, let's talk about Connect to signal generator.

63
00:05:30,877 --> 00:05:39,927
sig_gen = serial.Serial('/dev/ttyUSB0', 115200)

64
00:05:39,927 --> 00:05:43,305
Moving on to Connect to Arduino for photon counting.

65
00:05:43,305 --> 00:05:51,370
arduino = serial.Serial('/dev/ttyACM0', 115200)

66
00:05:51,362 --> 00:06:04,557
def set_frequency(freq_hz): """Set signal generator frequency""" cmd = f"FREQ {freq_hz}\n" sig_gen.write(cmd.encode())

67
00:06:04,557 --> 00:06:20,410
def count_photons(duration_ms=100): """Count photons for given duration""" arduino.write(f"COUNT {duration_ms}\n".encode()) result = arduino.readline().decode().strip() return int(result)

68
00:06:20,410 --> 00:06:22,658
Next up: Sweep parameters.

69
00:06:22,658 --> 00:06:48,848
freq_start = 2.75e9  # 2.75 GHz freq_stop = 2.95e9   # 2.95 GHz freq_step = 5e6      # 5 MHz num_points = int((freq_stop - freq_start) / freq_step)

70
00:06:48,848 --> 00:06:50,723
Let's explore Perform sweep.

71
00:06:50,723 --> 00:06:53,631
frequencies = [] fluorescence = []

72
00:06:53,631 --> 00:07:09,160
for i in range(num_points): freq = freq_start + i * freq_step set_frequency(freq) time.sleep(0.05)  # Wait for frequency to settle

73
00:07:09,160 --> 00:07:12,393
counts = count_photons(100)

74
00:07:12,393 --> 00:07:21,780
frequencies.append(freq / 1e9)  # Convert to GHz fluorescence.append(counts)

75
00:07:21,780 --> 00:07:29,509
print(f"Freq: {freq/1e9:.3f} GHz, Counts: {counts}")

76
00:07:29,509 --> 00:07:31,011
Now let's look at Plot result.

77
00:07:31,011 --> 00:07:55,578
plt.figure(figsize=(10, 6)) plt.plot(frequencies, fluorescence, 'b.-') plt.xlabel('Frequency (GHz)') plt.ylabel('Fluorescence (counts)') plt.title('ODMR Spectrum of NV Center') plt.grid(True) plt.savefig('odmr_spectrum.png') plt.show()

